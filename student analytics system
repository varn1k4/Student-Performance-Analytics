<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Faculty Portal</title>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

:root{
--bg:#050a18;
--bg2:#0a1128;
--glass:rgba(10,20,60,0.55);
--glass2:rgba(15,30,80,0.7);
--border:rgba(60,120,255,0.18);
--border2:rgba(60,120,255,0.35);

--blue:#3b82f6;
--blue2:#1d4ed8;
--blue3:#60a5fa;

--text:#e2e8f0;
--text2:#94a3b8;
--text3:#64748b;

--accent:#1e40af;
--glow:rgba(59,130,246,0.15);
}

body{
font-family:'Segoe UI',system-ui,sans-serif;
background:var(--bg);
color:var(--text);
min-height:100vh;
overflow-x:hidden;
}

.bg-orbs{
position:fixed;
inset:0;
pointer-events:none;
z-index:0;
}

.orb{
position:absolute;
border-radius:50%;
filter:blur(60px);
opacity:.12;
}

.orb1{
width:400px;
height:400px;
background:#1d4ed8;
top:-100px;
left:-100px;
}

.orb2{
width:300px;
height:300px;
background:#1e3a8a;
bottom:-50px;
right:-50px;
}

.orb3{
width:200px;
height:200px;
background:#3b82f6;
top:50%;
left:50%;
transform:translate(-50%,-50%);
}

#app{
position:relative;
z-index:1;
min-height:100vh;
}

.page{
display:none;
min-height:100vh;
}

.page.active{
display:block;
}

/* LOGIN + SIGNUP */

.auth-wrap{
display:flex;
align-items:center;
justify-content:center;
min-height:100vh;
padding:24px;
}

.auth-card{
width:100%;
max-width:420px;
padding:40px;
border-radius:24px;
backdrop-filter:blur(24px);
background:rgba(10,20,60,.7);
border:1px solid var(--border2);
}

.auth-logo{
text-align:center;
margin-bottom:32px;
}

.auth-logo .icon-wrap{
width:64px;
height:64px;
background:linear-gradient(
135deg,
#1d4ed8,
#3b82f6
);

border-radius:16px;

display:inline-flex;
align-items:center;
justify-content:center;

margin-bottom:12px;
}

.auth-logo i{
font-size:32px;
color:white;
}

.auth-logo h1{
font-size:22px;
font-weight:600;
}

.auth-logo p{
font-size:13px;
color:var(--text2);
margin-top:4px;
}

.field{
margin-bottom:18px;
}

.field label{
display:block;
font-size:12px;
font-weight:500;
margin-bottom:6px;
color:var(--text2);
text-transform:uppercase;
letter-spacing:.5px;
}

.field input{
width:100%;
padding:11px 14px;

background:
rgba(15,30,80,.5);

border:1px solid
var(--border2);

border-radius:10px;

color:var(--text);
font-size:14px;
outline:none;
}

.field input:focus{
border-color:var(--blue);
box-shadow:
0 0 0 3px
rgba(59,130,246,.12);
}

.field input::placeholder{
color:var(--text3);
}

.btn{
width:100%;
padding:12px;

border:none;
border-radius:10px;

font-size:14px;
font-weight:500;

cursor:pointer;
}

.btn-primary{
background:
linear-gradient(
135deg,
#1d4ed8,
#3b82f6
);

color:white;
}

.btn-primary:hover{
opacity:.9;
}

.auth-switch{
text-align:center;
margin-top:20px;
font-size:13px;
color:var(--text2);
}

.auth-switch a{
color:var(--blue3);
cursor:pointer;
text-decoration:none;
}

.auth-switch a:hover{
text-decoration:underline;
}

.error-msg{
background:
rgba(239,68,68,.12);

border:
1px solid
rgba(239,68,68,.3);

border-radius:8px;

padding:10px 14px;

font-size:13px;
color:#fca5a5;

margin-bottom:14px;

display:none;
}

/* PORTAL LAYOUT */

.portal-layout{
display:flex;
min-height:100vh;
}

/* SIDEBAR */

.sidebar{
width:220px;
min-width:220px;

padding:20px 14px;

backdrop-filter:blur(20px);

background:
rgba(5,12,35,.8);

border-right:
1px solid var(--border);

display:flex;
flex-direction:column;
}

.sidebar-logo{
display:flex;
align-items:center;
gap:10px;

padding:8px 6px;

margin-bottom:28px;
}

.sidebar-logo .logo-icon{
width:36px;
height:36px;

background:
linear-gradient(
135deg,
#1d4ed8,
#3b82f6
);

border-radius:10px;

display:flex;
align-items:center;
justify-content:center;
}

.sidebar-logo .logo-icon i{
font-size:18px;
color:white;
}

.sidebar-logo span{
font-size:15px;
font-weight:600;
color:var(--text);
}

.nav-section{
margin-bottom:24px;
}

.nav-label{
font-size:10px;
font-weight:600;

color:var(--text3);

text-transform:uppercase;
letter-spacing:1px;

padding:0 8px;
margin-bottom:8px;
}

.nav-item{
display:flex;
align-items:center;
gap:10px;

padding:9px 10px;

border-radius:10px;

cursor:pointer;

color:var(--text2);

font-size:13px;

border:1px solid transparent;

transition:.2s;
}

.nav-item:hover{
background:
rgba(59,130,246,.08);

color:var(--text);
}

.nav-item.active{
background:
rgba(59,130,246,.15);

border-color:
rgba(59,130,246,.25);

color:var(--blue3);
}

.nav-item i{
font-size:16px;
}

.sidebar-footer{
margin-top:auto;
padding-top:16px;

border-top:
1px solid var(--border);
}

.user-info{
display:flex;
align-items:center;
gap:10px;

padding:8px 6px;
}

.user-avatar{
width:34px;
height:34px;

border-radius:50%;

background:
linear-gradient(
135deg,
#1e40af,
#3b82f6
);

display:flex;
align-items:center;
justify-content:center;

font-size:13px;
font-weight:600;

color:white;
}

.user-name{
font-size:13px;
font-weight:500;
}

.user-email{
font-size:11px;
color:var(--text3);
}

.logout-btn{
display:flex;
align-items:center;
gap:8px;

padding:8px 10px;

border-radius:8px;

cursor:pointer;

font-size:12px;

border:none;
background:none;

width:100%;

color:var(--text3);
}

.logout-btn:hover{
background:
rgba(239,68,68,.1);

color:#fca5a5;
}

/* CONTENT */

.content{
flex:1;
padding:24px;
overflow-y:auto;
}

.page-header{
margin-bottom:24px;
}

.page-header h2{
font-size:20px;
font-weight:600;
}

.page-header p{
font-size:13px;
color:var(--text2);
margin-top:3px;
}

/* CARDS */

.card{
backdrop-filter:blur(16px);

background:
rgba(10,20,60,.55);

border:
1px solid var(--border);

border-radius:16px;

padding:20px;
}

.card-title{
font-size:14px;
font-weight:600;

display:flex;
align-items:center;
gap:8px;

margin-bottom:16px;
}

.card-title i{
font-size:16px;
color:var(--blue3);
}

/* DASHBOARD STATS */

.stats-row{
display:grid;

grid-template-columns:
repeat(3,1fr);

gap:14px;

margin-bottom:20px;
}

.stat-card{
background:
rgba(10,20,60,.55);

border:
1px solid var(--border);

border-radius:14px;

padding:16px 18px;
}

.stat-icon{
width:36px;
height:36px;

border-radius:10px;

display:flex;
align-items:center;
justify-content:center;

margin-bottom:10px;
}

.stat-icon.blue{
background:
rgba(59,130,246,.15);
}

.stat-icon.green{
background:
rgba(34,197,94,.12);
}

.stat-icon.purple{
background:
rgba(168,85,247,.12);
}

.stat-icon.blue i{
color:#60a5fa;
}

.stat-icon.green i{
color:#86efac;
}

.stat-icon.purple i{
color:#c4b5fd;
}

.stat-num{
font-size:26px;
font-weight:700;
}

.stat-label{
font-size:12px;
color:var(--text2);
margin-top:3px;
}

/* TABLES */

.data-table{
width:100%;
border-collapse:collapse;
}

.data-table th{
padding:10px 12px;

font-size:11px;
font-weight:600;

color:var(--text3);

text-transform:uppercase;

letter-spacing:.5px;

text-align:left;

border-bottom:
1px solid var(--border);
}

.data-table td{
padding:10px 12px;

font-size:13px;

border-bottom:
1px solid rgba(60,120,255,.06);
}

.data-table tr:hover td{
background:
rgba(59,130,246,.04);
}

.table-wrap{
overflow-x:auto;
}

/* BADGES */

.badge{
display:inline-flex;
align-items:center;

padding:3px 10px;

border-radius:20px;

font-size:11px;
font-weight:500;
}

.badge-blue{
background:
rgba(59,130,246,.15);

color:#93c5fd;

border:
1px solid
rgba(59,130,246,.25);
}

.badge-green{
background:
rgba(34,197,94,.12);

color:#86efac;

border:
1px solid
rgba(34,197,94,.2);
}

.badge-amber{
background:
rgba(245,158,11,.12);

color:#fcd34d;

border:
1px solid
rgba(245,158,11,.2);
}

.badge-red{
background:
rgba(239,68,68,.12);

color:#fca5a5;

border:
1px solid
rgba(239,68,68,.2);
}

.badge-purple{
background:
rgba(168,85,247,.12);

color:#c4b5fd;

border:
1px solid
rgba(168,85,247,.2);
}
/* FORM ROW */

.form-row{
display:flex;
gap:10px;
margin-bottom:16px;
flex-wrap:wrap;
}

.form-group{
display:flex;
flex-direction:column;
gap:5px;

flex:1;
min-width:140px;
}

.form-group label{
font-size:11px;
font-weight:600;

color:var(--text3);

text-transform:uppercase;
letter-spacing:.5px;
}

.form-group input,
.form-group select{

padding:9px 12px;

background:
rgba(15,30,80,.5);

border:
1px solid var(--border2);

border-radius:9px;

color:var(--text);

font-size:13px;
outline:none;
}

.form-group input:focus,
.form-group select:focus{
border-color:var(--blue);
}

.form-group input::placeholder{
color:var(--text3);
}

.form-group select option{
background:#0a1128;
color:var(--text);
}

/* BUTTONS */

.btn-sm{
padding:9px 16px;

border:none;
border-radius:9px;

font-size:13px;
font-weight:500;

cursor:pointer;
}

.btn-blue{
background:
linear-gradient(
135deg,
#1d4ed8,
#3b82f6
);

color:white;
}

.btn-blue:hover{
opacity:.9;
}

.btn-ghost{
background:
rgba(59,130,246,.1);

border:
1px solid var(--border2);

color:var(--blue3);
}

.btn-ghost:hover{
background:
rgba(59,130,246,.18);
}

.btn-danger{
background:
rgba(239,68,68,.12);

border:
1px solid
rgba(239,68,68,.3);

color:#fca5a5;
}

.btn-danger:hover{
background:
rgba(239,68,68,.2);
}

.btn-sm i{
font-size:14px;
vertical-align:-2px;
margin-right:4px;
}

/* TABS */

.tabs{
display:flex;
gap:4px;

margin-bottom:20px;

background:
rgba(10,20,60,.4);

border:
1px solid var(--border);

border-radius:12px;

padding:4px;
}

.tab{
padding:8px 18px;

border-radius:9px;

font-size:13px;
font-weight:500;

cursor:pointer;

color:var(--text2);

border:1px solid transparent;
}

.tab.active{
background:
rgba(59,130,246,.2);

border-color:
rgba(59,130,246,.35);

color:var(--blue3);
}

/* SUBJECT CARDS */

.subject-grid{
display:grid;

grid-template-columns:
repeat(auto-fill,minmax(220px,1fr));

gap:14px;

margin-bottom:20px;
}

.subject-card{
background:
rgba(10,20,60,.55);

border:
1px solid var(--border);

border-radius:14px;

padding:16px;

cursor:pointer;

transition:.2s;
}

.subject-card:hover{
border-color:var(--border2);

background:
rgba(15,30,80,.65);
}

.subject-card.sel{
border-color:
rgba(59,130,246,.5);

background:
rgba(30,64,175,.15);
}

.subject-name{
font-size:14px;
font-weight:600;

margin-bottom:4px;
}

.subject-code{
font-size:11px;
color:var(--text3);
}

.subject-meta{
display:flex;
align-items:center;
gap:8px;

margin-top:12px;

font-size:12px;
color:var(--text2);
}

/* CHARTS */

.chart-grid{
display:grid;

grid-template-columns:
1fr 1fr;

gap:16px;

margin-top:20px;
}

.chart-wrap{
background:
rgba(10,20,60,.55);

border:
1px solid var(--border);

border-radius:16px;

padding:18px;
}

.chart-title{
font-size:13px;
font-weight:600;

margin-bottom:14px;
}

.chart-full{
background:
rgba(10,20,60,.55);

border:
1px solid var(--border);

border-radius:16px;

padding:18px;

margin-top:16px;
}

/* EXCEL IMPORT */

.upload-zone{
border:2px dashed
var(--border2);

border-radius:14px;

padding:32px;

text-align:center;

cursor:pointer;

background:
rgba(59,130,246,.03);

transition:.2s;
}

.upload-zone:hover{
border-color:var(--blue);

background:
rgba(59,130,246,.07);
}

.upload-zone i{
font-size:36px;
color:var(--blue3);

margin-bottom:12px;
}

.upload-zone p{
font-size:14px;
color:var(--text2);
}

.upload-zone small{
font-size:12px;
color:var(--text3);
}

/* GRADE COLORS */

.grade-A{
color:#86efac;
}

.grade-B{
color:#93c5fd;
}

.grade-C{
color:#fcd34d;
}

.grade-D{
color:#fdba74;
}

.grade-F{
color:#fca5a5;
}

/* MODAL */

.modal-overlay{
position:fixed;
inset:0;

background:
rgba(0,0,0,.6);

backdrop-filter:blur(4px);

z-index:100;

display:none;

align-items:center;
justify-content:center;
}

.modal-overlay.show{
display:flex;
}

.modal{
background:#0d1a3a;

border:
1px solid var(--border2);

border-radius:20px;

padding:28px;

width:100%;
max-width:440px;

max-height:80vh;
overflow-y:auto;
}

.modal h3{
font-size:16px;
font-weight:600;

margin-bottom:20px;
}

/* EMPTY STATE */

.empty-state{
text-align:center;
padding:40px;

color:var(--text3);
}

.empty-state i{
display:block;

font-size:40px;

margin-bottom:12px;
}

.empty-state p{
font-size:13px;
}

/* TOAST */

.toast{
position:fixed;

bottom:20px;
right:20px;

background:#1e3a8a;

border:
1px solid var(--border2);

border-radius:10px;

padding:12px 18px;

font-size:13px;

z-index:999;

display:none;
}

/* SCROLLBAR */

::-webkit-scrollbar{
width:5px;
}

::-webkit-scrollbar-track{
background:transparent;
}

::-webkit-scrollbar-thumb{
background:
rgba(59,130,246,.25);

border-radius:3px;
}

/* RESPONSIVE */

@media(max-width:900px){

.portal-layout{
flex-direction:column;
}

.sidebar{
width:100%;
min-width:100%;

border-right:none;

border-bottom:
1px solid var(--border);
}

.chart-grid{
grid-template-columns:1fr;
}

.stats-row{
grid-template-columns:1fr;
}
}

</style>
</head>
<body>

    
<!-- BACKGROUND ORBS -->

<div class="bg-orbs">

    <div class="orb orb1"></div>

    <div class="orb orb2"></div>

    <div class="orb orb3"></div>

</div>

<div id="app">

    <!-- LOGIN PAGE -->

    <div id="loginPage"
         class="page active">

        <div class="auth-wrap">

            <div class="auth-card">

                <div class="auth-logo">

                    <div class="icon-wrap">
                        <i class="ti ti-school"></i>
                    </div>

                    <h1>Faculty Portal</h1>

                    <p>
                        Faculty & Student
                        Management System
                    </p>

                </div>

                <div id="loginError"
                     class="error-msg">
                </div>

                <div class="field">

                    <label>Email</label>

                    <input
                        type="email"
                        id="loginEmail"
                        placeholder="faculty@example.com">

                </div>

                <div class="field">

                    <label>Password</label>

                    <input
                        type="password"
                        id="loginPassword"
                        placeholder="Enter password">

                </div>

                <button
                    class="btn btn-primary"
                    onclick="login()">

                    Login

                </button>

                <div class="auth-switch">

                    Don't have an account?

                    <a onclick="showSignup()">
                        Create One
                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- SIGNUP PAGE -->

    <div id="signupPage"
         class="page">

        <div class="auth-wrap">

            <div class="auth-card">

                <div class="auth-logo">

                    <div class="icon-wrap">
                        <i class="ti ti-user-plus"></i>
                    </div>

                    <h1>Create Account</h1>

                    <p>
                        Register Faculty Account
                    </p>

                </div>

                <div id="signupError"
                     class="error-msg">
                </div>

                <div class="field">

                    <label>Faculty Name</label>

                    <input
                        type="text"
                        id="facultyName"
                        placeholder="Faculty Name">

                </div>

                <div class="field">

                    <label>Email</label>

                    <input
                        type="email"
                        id="facultyEmail"
                        placeholder="faculty@example.com">

                </div>

                <div class="field">

                    <label>Department</label>

                    <input
                        type="text"
                        id="facultyDepartment"
                        placeholder="Computer Science">

                </div>

                <div class="field">

                    <label>Password</label>

                    <input
                        type="password"
                        id="facultyPassword"
                        placeholder="Create password">

                </div>

                <button
                    class="btn btn-primary"
                    onclick="signup()">

                    Create Account

                </button>

                <div class="auth-switch">

                    Already registered?

                    <a onclick="showLogin()">
                        Login
                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- PORTAL PAGE -->

    <div id="portalPage"
         class="page">

        <div class="portal-layout">

            <!-- SIDEBAR -->

            <aside class="sidebar">

                <div class="sidebar-logo">

                    <div class="logo-icon">
                        <i class="ti ti-school"></i>
                    </div>

                    <span>
                        Faculty Portal
                    </span>

                </div>

                <div class="nav-section">

                    <div class="nav-label">
                        Main Menu
                    </div>

                    <div
                        class="nav-item active"
                        onclick="showSection('dashboard',this)">

                        <i class="ti ti-layout-dashboard"></i>

                        Dashboard

                    </div>

                    <div
                        class="nav-item"
                        onclick="showSection('students',this)">

                        <i class="ti ti-users"></i>

                        Students

                    </div>

                    <div
                        class="nav-item"
                        onclick="showSection('subjects',this)">

                        <i class="ti ti-book"></i>

                        Subjects

                    </div>

                    <div
                        class="nav-item"
                        onclick="showSection('grades',this)">

                        <i class="ti ti-report-analytics"></i>

                        Grades

                    </div>

                    <div
                        class="nav-item"
                        onclick="showSection('analytics',this)">

                        <i class="ti ti-chart-bar"></i>

                        Analytics

                    </div>

                    <div
                        class="nav-item"
                        onclick="showSection('excel',this)">

                        <i class="ti ti-file-import"></i>

                        Excel Import

                    </div>

                </div>                <div class="sidebar-footer">

                    <div class="user-info">

                        <div class="user-avatar"
                             id="userAvatar">

                            F

                        </div>

                        <div>

                            <div class="user-name"
                                 id="userName">

                                Faculty

                            </div>

                            <div class="user-email"
                                 id="userEmail">

                                faculty@example.com

                            </div>

                        </div>

                    </div>

                    <button
                        class="logout-btn"
                        onclick="logout()">

                        <i class="ti ti-logout"></i>

                        Logout

                    </button>

                </div>

            </aside>

            <!-- CONTENT -->

            <main class="content">

                <!-- DASHBOARD -->

                <section
                    id="dashboardSection">

                    <div class="page-header">

                        <h2>
                            Dashboard
                        </h2>

                        <p>
                            Overview of students,
                            subjects and grades
                        </p>

                    </div>

                    <div class="stats-row">

                        <div class="stat-card">

