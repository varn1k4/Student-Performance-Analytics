/* =====================================
   EXCEL IMPORT
===================================== */

function importExcel(event){

const file =
event.target.files[0];

if(!file){

showToast(
"No file selected"
);

return;
}

const reader =
new FileReader();

reader.onload =
function(e){

const data =
new Uint8Array(
e.target.result
);

const workbook =
XLSX.read(
data,
{
type:"array"
}
);

const sheetName =
workbook.SheetNames[0];

const worksheet =
workbook.Sheets[
sheetName
];

const jsonData =
XLSX.utils.sheet_to_json(
worksheet
);

let imported = 0;

jsonData.forEach(row=>{

const roll =
row.Roll ||
row.roll ||
row.RollNo ||
row["Roll No"];

const name =
row.Name ||
row.name ||
row.Student;

const email =
row.Email ||
row.email ||
"";

if(
roll &&
name
){

const exists =
students.find(
s =>
s.roll ==
roll
);

if(!exists){

students.push({

roll:String(
roll
),

name:String(
name
),

email:String(
email
)

});

imported++;

}

}

});

saveStudents();

loadStudents();

populateDropdowns();

updateDashboard();

showToast(
imported +
" students imported"
);

};

reader.readAsArrayBuffer(
file
);

}


