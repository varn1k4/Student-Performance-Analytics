<script>

/* =====================================
   DATA STORAGE
===================================== */

let students =
JSON.parse(
localStorage.getItem("students")
) || [];

let subjects =
JSON.parse(
localStorage.getItem("subjects")
) || [];

let grades =
JSON.parse(
localStorage.getItem("grades")
) || [];

let currentFaculty =
JSON.parse(
localStorage.getItem("faculty")
) || null;

let performanceChart;
let distributionChart;
let analyticsChart;

/* =====================================
   AUTH FUNCTIONS
===================================== */

function showSignup(){

document
.getElementById("loginPage")
.classList.remove("active");

document
.getElementById("signupPage")
.classList.add("active");

}

function showLogin(){

document
.getElementById("signupPage")
.classList.remove("active");

document
.getElementById("loginPage")
.classList.add("active");

}

function signup(){

const name =
document.getElementById(
"facultyName"
).value;

const email =
document.getElementById(
"facultyEmail"
).value;

const dept =
document.getElementById(
"facultyDepartment"
).value;

const password =
document.getElementById(
"facultyPassword"
).value;

if(
!name ||
!email ||
!dept ||
!password
){

showError(
"signupError",
"Please fill all fields"
);

return;
}

const faculty = {
name,
email,
dept,
password
};

localStorage.setItem(
"faculty",
JSON.stringify(faculty)
);

showToast(
"Account Created Successfully"
);

showLogin();

}
function login(){

const email =
document.getElementById(
"loginEmail"
).value;

const password =
document.getElementById(
"loginPassword"
).value;

const faculty =
JSON.parse(
localStorage.getItem(
"faculty"
)
);

if(
!faculty ||
faculty.email !== email ||
faculty.password !== password
){

showError(
"loginError",
"Invalid Email or Password"
);

return;
}

currentFaculty = faculty;

document
.getElementById("loginPage")
.classList.remove("active");

document
.getElementById("portalPage")
.classList.add("active");

loadFacultyInfo();

initializePortal();

showToast(
"Login Successful"
);

}

function logout(){

document
.getElementById("portalPage")
.classList.remove("active");

document
.getElementById("loginPage")
.classList.add("active");

showToast(
"Logged Out Successfully"
);

}

/* =====================================
   PORTAL INITIALIZATION
===================================== */

function initializePortal(){

loadStudents();

loadSubjects();

loadGrades();

updateDashboard();

populateDropdowns();

renderCharts();

}

function loadFacultyInfo(){

if(!currentFaculty) return;

document
.getElementById("userName")
.innerText =
currentFaculty.name;

document
.getElementById("userEmail")
.innerText =
currentFaculty.email;

document
.getElementById("userAvatar")
.innerText =
currentFaculty.name
.charAt(0)
.toUpperCase();

}

/* =====================================
   NAVIGATION
===================================== */

function showSection(
section,
element
){

const sections = [

"dashboardSection",
"studentsSection",
"subjectsSection",
"gradesSection",
"analyticsSection",
"excelSection"

];

sections.forEach(id=>{

document
.getElementById(id)
.style.display="none";

});

document
.querySelectorAll(
".nav-item"
)
.forEach(item=>{

item.classList.remove(
"active"
);

});

element.classList.add(
"active"
);

document
.getElementById(
section + "Section"
)
.style.display =
"block";

if(
section === "analytics"
){

renderAnalyticsChart();

}

}

/* =====================================
   TOAST MESSAGE
===================================== */

function showToast(message){

const toast =
document.getElementById(
"toast"
);

toast.innerText =
message;

toast.style.display =
"block";

setTimeout(()=>{

toast.style.display =
"none";

},3000);

}

/* =====================================
   ERROR HANDLER
===================================== */

function showError(
id,
message
){

const element =
document.getElementById(id);

element.innerText =
message;

element.style.display =
"block";

setTimeout(()=>{

element.style.display =
"none";

},3000);

}

/* =====================================
   LOCAL STORAGE SAVE
===================================== */

function saveStudents(){

localStorage.setItem(
"students",
JSON.stringify(
students
)
);

}

function saveSubjects(){

localStorage.setItem(
"subjects",
JSON.stringify(
subjects
)
);

}

function saveGrades(){

localStorage.setItem(
"grades",
JSON.stringify(
grades
)
);

}


/* =====================================
   STUDENT MANAGEMENT
===================================== */

function addStudent(){

const roll =
document.getElementById(
"studentRoll"
).value.trim();

const name =
document.getElementById(
"studentName"
).value.trim();

const email =
document.getElementById(
"studentEmail"
).value.trim();

if(
!roll ||
!name ||
!email
){
showToast(
"Fill all student fields"
);
return;
}

const exists =
students.find(
s => s.roll === roll
);

if(exists){

showToast(
"Student already exists"
);

return;
}

students.push({

roll,
name,
email

});

saveStudents();

loadStudents();

populateDropdowns();

updateDashboard();

document.getElementById(
"studentRoll"
).value = "";

document.getElementById(
"studentName"
).value = "";

document.getElementById(
"studentEmail"
).value = "";

showToast(
"Student Added"
);

}

function deleteStudent(
roll
){

if(
!confirm(
"Delete student?"
)
){
return;
}

students =
students.filter(
s => s.roll !== roll
);

grades =
grades.filter(
g => g.roll !== roll
);

saveStudents();

saveGrades();

loadStudents();

loadGrades();

populateDropdowns();

updateDashboard();

renderCharts();

showToast(
"Student Deleted"
);

}

function loadStudents(){

const tbody =
document.getElementById(
"studentsTableBody"
);

if(!tbody) return;

tbody.innerHTML = "";

if(
students.length === 0
){

tbody.innerHTML = `
<tr>
<td colspan="4">
<div class="empty-state">
<i class="ti ti-users"></i>
<p>
No Students Found
</p>
</div>
</td>
</tr>
`;

return;
}

students.forEach(
student => {

tbody.innerHTML += `
<tr>

<td>
${student.roll}
</td>

<td>
${student.name}
</td>

<td>
${student.email}
</td>

<td>

<button
class="btn-sm btn-danger"
onclick="deleteStudent('${student.roll}')">

Delete

</button>

</td>

</tr>
`;

});

}

/* =====================================
   DASHBOARD COUNTS
===================================== */

function updateDashboard(){

document.getElementById(
"studentCount"
).innerText =
students.length;

document.getElementById(
"subjectCount"
).innerText =
subjects.length;

if(
grades.length === 0
){

document.getElementById(
"averageGrade"
).innerText =
"0%";

return;
}

let total = 0;

grades.forEach(
g => {

total += Number(
g.score
);

});

const avg =
(
total /
grades.length
).toFixed(1);

document.getElementById(
"averageGrade"
).innerText =
avg + "%";

}

/* =====================================
   SUBJECT MANAGEMENT
===================================== */

function addSubject(){

const code =
document.getElementById(
"subjectCode"
).value.trim();

const name =
document.getElementById(
"subjectNameInput"
).value.trim();

if(
!code ||
!name
){

showToast(
"Fill all subject fields"
);

return;
}

const exists =
subjects.find(
s => s.code === code
);

if(exists){

showToast(
"Subject already exists"
);

return;
}

subjects.push({

code,
name

});

saveSubjects();

loadSubjects();

populateDropdowns();

updateDashboard();

document.getElementById(
"subjectCode"
).value = "";

document.getElementById(
"subjectNameInput"
).value = "";

showToast(
"Subject Added"
);

}

function deleteSubject(
code
){

if(
!confirm(
"Delete subject?"
)
){
return;
}

subjects =
subjects.filter(
s => s.code !== code
);

grades =
grades.filter(
g => g.subject !== code
);

saveSubjects();

saveGrades();

loadSubjects();

loadGrades();

populateDropdowns();

updateDashboard();

renderCharts();

showToast(
"Subject Deleted"
);

}

function loadSubjects(){

const grid =
document.getElementById(
"subjectsGrid"
);

if(!grid) return;

grid.innerHTML = "";

if(
subjects.length === 0
){

grid.innerHTML = `
<div class="empty-state">
<i class="ti ti-book"></i>
<p>
No Subjects Available
</p>
</div>
`;

return;
}

subjects.forEach(
subject => {

grid.innerHTML += `

<div class="subject-card">

<div class="subject-name">
${subject.name}
</div>

<div class="subject-code">
${subject.code}
</div>

<div class="subject-meta">

<span class="badge badge-blue">
Subject
</span>

<button
class="btn-sm btn-danger"
onclick="deleteSubject('${subject.code}')">

Delete

</button>

</div>

</div>

`;

});

}

/* =====================================
   DROPDOWNS
===================================== */

function populateDropdowns(){

const studentSelect =
document.getElementById(
"gradeStudent"
);

const subjectSelect =
document.getElementById(
"gradeSubject"
);

if(
!studentSelect ||
!subjectSelect
){
return;
}

studentSelect.innerHTML =
`<option value="">
Select Student
</option>`;

subjectSelect.innerHTML =
`<option value="">
Select Subject
</option>`;

students.forEach(
student => {

studentSelect.innerHTML += `
<option value="${student.roll}">
${student.roll}
 - ${student.name}
</option>
`;

});

subjects.forEach(
subject => {

subjectSelect.innerHTML += `
<option value="${subject.code}">
${subject.code}
 - ${subject.name}
</option>
`;

});

}


/* =====================================
   GRADE MANAGEMENT
===================================== */

function getGrade(score){

score = Number(score);

if(score >= 90){
return "A";
}

if(score >= 80){
return "B";
}

if(score >= 70){
return "C";
}

if(score >= 60){
return "D";
}

return "F";

}

function getGradeClass(score){

const grade =
getGrade(score);

switch(grade){

case "A":
return "grade-A";

case "B":
return "grade-B";

case "C":
return "grade-C";

case "D":
return "grade-D";

default:
return "grade-F";

}

}

function saveGrade(){

const roll =
document.getElementById(
"gradeStudent"
).value;

const subject =
document.getElementById(
"gradeSubject"
).value;

const score =
document.getElementById(
"gradeScore"
).value;

if(
!roll ||
!subject ||
!score
){

showToast(
"Fill all grade fields"
);

return;
}

const existing =
grades.find(
g =>
g.roll === roll &&
g.subject === subject
);

if(existing){

showToast(
"Grade already exists"
);

return;
}

grades.push({

roll,
subject,
score

});

saveGrades();

loadGrades();

updateDashboard();

renderCharts();

document.getElementById(
"gradeScore"
).value = "";

showToast(
"Grade Saved"
);

}

function deleteGrade(
index
){

if(
!confirm(
"Delete grade record?"
)
){
return;
}

grades.splice(
index,
1
);

saveGrades();

loadGrades();

updateDashboard();

renderCharts();

showToast(
"Grade Deleted"
);

}

function loadGrades(){

const tbody =
document.getElementById(
"gradesTableBody"
);

if(!tbody) return;

tbody.innerHTML = "";

if(
grades.length === 0
){

tbody.innerHTML = `
<tr>
<td colspan="5">

<div class="empty-state">

<i class="ti ti-report"></i>

<p>
No Grades Available
</p>

</div>

</td>
</tr>
`;

return;
}

grades.forEach(
(
grade,
index
)=>{

const student =
students.find(
s =>
s.roll === grade.roll
);

const subject =
subjects.find(
s =>
s.code === grade.subject
);

tbody.innerHTML += `

<tr>

<td>
${student ? student.name : grade.roll}
</td>

<td>
${subject ? subject.name : grade.subject}
</td>

<td>
${grade.score}
</td>

<td>

<span
class="${getGradeClass(
grade.score
)}">

${getGrade(
grade.score
)}

</span>

</td>

<td>

<button
class="btn-sm btn-danger"
onclick="deleteGrade(${index})">

Delete

</button>

</td>

</tr>

`;

});

}
/* =====================================
   CHARTS
===================================== */

function renderCharts(){

renderPerformanceChart();

renderDistributionChart();

}

function renderPerformanceChart(){

const canvas =
document.getElementById(
"performanceChart"
);

if(!canvas) return;

const ctx =
canvas.getContext("2d");

if(performanceChart){

performanceChart.destroy();

}

const labels = [];
const scores = [];

grades.forEach(g=>{

const student =
students.find(
s=>s.roll===g.roll
);

labels.push(
student
? student.name
: g.roll
);

scores.push(
Number(g.score)
);

});

performanceChart =
new Chart(ctx,{

type:"bar",

data:{

labels:labels,

datasets:[{

label:"Score",

data:scores,

borderWidth:1

}]

},

options:{

responsive:true,

plugins:{

legend:{
display:false
}

},

scales:{

y:{
beginAtZero:true,
max:100
}

}

}

});

}

function renderDistributionChart(){

const canvas =
document.getElementById(
"distributionChart"
);

if(!canvas) return;

const ctx =
canvas.getContext("2d");

if(distributionChart){

distributionChart.destroy();

}

let A=0;
let B=0;
let C=0;
let D=0;
let F=0;

grades.forEach(g=>{

const grade =
getGrade(
g.score
);

if(grade==="A") A++;
else if(grade==="B") B++;
else if(grade==="C") C++;
else if(grade==="D") D++;
else F++;

});

distributionChart =
new Chart(ctx,{

type:"pie",

data:{

labels:[
"A",
"B",
"C",
"D",
"F"
],

datasets:[{

data:[
A,
B,
C,
D,
F
]

}]

},

options:{
responsive:true
}

});

}

function renderAnalyticsChart(){

const canvas =
document.getElementById(
"analyticsChart"
);

if(!canvas) return;

const ctx =
canvas.getContext("2d");

if(analyticsChart){

analyticsChart.destroy();

}

const labels = [];
const averages = [];

subjects.forEach(subject=>{

const subjectGrades =
grades.filter(
g =>
g.subject ===
subject.code
);

let avg = 0;

if(
subjectGrades.length > 0
){

subjectGrades.forEach(g=>{

avg +=
Number(
g.score
);

});

avg =
avg /
subjectGrades.length;

}

labels.push(
subject.name
);

averages.push(
avg.toFixed(2)
);

});

analyticsChart =
new Chart(ctx,{

type:"line",

data:{

labels:labels,

datasets:[{

label:
"Average Score",

